# ═══════════════════════════════════════
# One Silk Ribbon — Environment Variables
# 复制此文件为 .env.local 并填入真实值
# ═══════════════════════════════════════

# Supabase（在 Supabase 后台 Settings > API 找到）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Stripe（在 Stripe 后台 Developers > API keys 找到）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# PayPal（在 PayPal Developer 后台找到）
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_MODE=live  # 或 sandbox（测试时用）

# AfterShip（在 AfterShip 后台 API > API Keys 找到）
AFTERSHIP_API_KEY=your_aftership_api_key

# Email（用于发送订单确认邮件，推荐用 Resend.com 免费账号）
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=orders@onesilkribbon.com

# 网站地址
NEXT_PUBLIC_SITE_URL=https://onesilkribbon.com
